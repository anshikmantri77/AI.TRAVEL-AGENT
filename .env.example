# ── LLM provider ──────────────────────────────────────────────────────────────
# Choose one: groq | anthropic | openai
LLM_PROVIDER=groq

# API keys — fill in only the one you need for your chosen provider
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: override the default model for the chosen provider
# LLM_MODEL=llama-3.3-70b-versatile

# ── Web search ─────────────────────────────────────────────────────────────────
SERPER_API_KEY=

# ── Application ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Session TTL in seconds (default: 1 hour)
SESSION_TTL_SECONDS=3600

# Maximum human-in-the-loop revision cycles before auto-finalise
MAX_REVISIONS=3

# ── Redis (production) ─────────────────────────────────────────────────────────
# Set USE_REDIS=true to swap the in-memory SessionStore for RedisSessionStore.
# Leave as false for local development (no Redis required).
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# ── Rate limiting ──────────────────────────────────────────────────────────────
# Maximum POST /plan requests per minute per IP address (SlowAPI).
RATE_LIMIT_PER_MINUTE=10
